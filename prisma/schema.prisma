// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- USER MANAGEMENT ---

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  image         String?
  password      String?   // Nullable: Google users won't have a password
  googleId      String?   @unique
  role          String    @default("USER") // USER, ADMIN, AUTHOR
  chaptersRead  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  readingHistory ReadingHistory[]
  library        Library[]
  reviews        Review[]
  comments       Comment[]
  commentLikes   CommentLike[]
  likes          Like[]
  nominations    Nomination[]
  chatMessages   ChatMessage[]
  storyRequests  StoryRequest[]
}

// --- STORY MANAGEMENT ---

model Story {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  author          String
  description     String?
  coverImage      String?
  status          String    @default("ONGOING")
  totalChapters   Int       @default(0)
  viewCount       Int       @default(0)
  ratingScore     Float     @default(0)
  ratingCount     Int       @default(0)
  followCount     Int       @default(0)
  likeCount       Int       @default(0)
  nominationCount Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  chapters        Chapter[]
  genres          Genre[]
  reviews         Review[]
  libraryEntries  Library[]
  historyEntries  ReadingHistory[]
  comments        Comment[]
  likes           Like[]
  nominations     Nomination[]
  storyRequests   StoryRequest[]
}

model Chapter {
  id          String   @id @default(uuid())
  index       Int
  title       String
  contentUrl  String?  // URL trỏ tới file txt trên Cloudflare R2
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  historyEntries ReadingHistory[]
  
  @@index([storyId, index])
}

model Genre {
  id          String   @id @default(uuid())
  name        String
  type        String   @default("GENRE")
  description String?

  // Relations
  stories     Story[]

  @@unique([name, type])
}

// --- USER INTERACTION ---

model ReadingHistory {
  id          String   @id @default(uuid())
  visitedAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  chapterId   String?
  chapter     Chapter? @relation(fields: [chapterId], references: [id])

  @@unique([userId, storyId])
}

model Library {
  id          String   @id @default(uuid())
  addedAt     DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
}

model Nomination {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Like {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
}

model Review {
  id          String   @id @default(uuid())
  rating      Int
  content     String?
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Comment {
  id          String   @id @default(uuid())
  content     String
  likeCount   Int      @default(0)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  commentLikes CommentLike[]

  @@index([storyId, createdAt])
}

model CommentLike {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  commentId   String
  comment     Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model StoryRequest {
  id          String   @id @default(uuid())
  title       String
  link        String?
  note        String?
  status      String   @default("PENDING") // PENDING, DONE, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Khi admin làm xong → link tới truyện trong app
  storyId     String?
  story       Story?   @relation(fields: [storyId], references: [id])

  @@index([status, createdAt])
}

model ChatMessage {
  id          String   @id @default(uuid())
  storySlug   String
  content     String
  likeCount   Int      @default(0)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storySlug, createdAt])
}
