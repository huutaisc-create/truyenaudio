// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- USER MANAGEMENT ---

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String?
  image           String?
  password        String?
  googleId        String?   @unique
  role            String    @default("USER")
  chaptersRead    Int       @default(0)
  downloadCredits Float     @default(0)      // Cộng dồn float, dùng khi >= 1.0
  lastCheckIn     DateTime? // Ngày điểm danh gần nhất (UTC midnight)
  currentStreak   Int       @default(0)      // Chuỗi ngày liên tiếp hiện tại
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  readingHistory     ReadingHistory[]
  library            Library[]
  reviews            Review[]
  comments           Comment[]
  commentLikes       CommentLike[]
  likes              Like[]
  nominations        Nomination[]
  chatMessages       ChatMessage[]
  storyRequests      StoryRequest[]
  creditTransactions CreditTransaction[]
  adminLogs          AdminLog[]          @relation("AdminLogs")
  userVips           UserVip[]
  payments           Payment[]
  fcmTokens          UserFcmToken[]
}

// --- CREDIT TRANSACTIONS (audit log) ---

model CreditTransaction {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         String   // 'ADD_APP' | 'ADD_WEB' | 'SPEND'
  amount       Float    // +1.0 / +0.5 / -1.0
  balanceAfter Float    // snapshot số dư sau giao dịch, dễ đối soát

  note         String?  // vd: "Xem video rewarded", "Tải chương xyz"

  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

// --- STORY MANAGEMENT ---

model Story {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  author          String
  description     String?
  coverImage      String?
  status          String    @default("ONGOING")
  totalChapters   Int       @default(0)
  viewCount       Int       @default(0)
  ratingScore     Float     @default(0)
  ratingCount     Int       @default(0)
  followCount     Int       @default(0)
  likeCount       Int       @default(0)
  nominationCount Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Admin fields
  storyType       String    @default("ORIGINAL")  // "ORIGINAL" | "CONVERT" | "TRANSLATED"
  isCompleted     Boolean   @default(false)        // dành cho convert/dịch: đã hoàn thành chưa
  isHidden        Boolean   @default(false)        // admin ẩn khỏi public
  sourceUrl       String?                          // link nguồn gốc (convert/dịch)
  translatorName  String?                          // tên dịch giả / converter

  chapters        Chapter[]
  genres          Genre[]
  reviews         Review[]
  libraryEntries  Library[]
  historyEntries  ReadingHistory[]
  comments        Comment[]
  likes           Like[]
  nominations     Nomination[]
  storyRequests   StoryRequest[]
}

model Chapter {
  id          String   @id @default(uuid())
  index       Int
  title       String
  contentUrl  String?
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  historyEntries ReadingHistory[]
  
  @@index([storyId, index])
}

model Genre {
  id          String   @id @default(uuid())
  name        String
  type        String   @default("GENRE")
  description String?

  stories     Story[]

  @@unique([name, type])
}

// --- USER INTERACTION ---

model ReadingHistory {
  id          String   @id @default(uuid())
  visitedAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  chapterId   String?
  chapter     Chapter? @relation(fields: [chapterId], references: [id])

  @@unique([userId, storyId])
}

model Library {
  id          String   @id @default(uuid())
  addedAt     DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
}

model Nomination {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Like {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
}

model Review {
  id          String   @id @default(uuid())
  rating      Int
  content     String
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Comment {
  id          String   @id @default(uuid())
  content     String
  likeCount   Int      @default(0)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  commentLikes CommentLike[]

  @@index([storyId, createdAt])
}

model CommentLike {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  commentId   String
  comment     Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model StoryRequest {
  id          String   @id @default(uuid())
  title       String
  link        String?
  note        String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  storyId     String?
  story       Story?   @relation(fields: [storyId], references: [id])

  @@index([status, createdAt])
}

model ChatMessage {
  id          String   @id @default(uuid())
  storySlug   String
  content     String
  likeCount   Int      @default(0)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storySlug, createdAt])
}

// --- ADMIN: Nhật ký hành động ---

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String
  admin      User     @relation("AdminLogs", fields: [adminId], references: [id], onDelete: Cascade)
  action     String                          // "DELETE_STORY" | "ADJUST_CREDIT" | ...
  targetType String?                         // "STORY" | "USER" | "COMMENT" | "REVIEW"
  targetId   String?
  detail     String?                         // JSON string chi tiết
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}

// --- ADMIN: Từ khóa cấm (blacklist comment/review) ---

model SpamKeyword {
  id        String   @id @default(uuid())
  keyword   String   @unique
  createdBy String
  createdAt DateTime @default(now())
}

// --- VIP SYSTEM ---

model VipPlan {
  id           String    @id @default(uuid())
  name         String                          // "VIP 1 tháng"
  price        Int                             // VNĐ
  durationDays Int
  benefits     Json                            // { noAds: bool, offlineUnlimited: bool, premiumVoices: bool }
  isActive     Boolean   @default(true)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  userVips  UserVip[]
  payments  Payment[]
}

model UserVip {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String
  plan      VipPlan  @relation(fields: [planId], references: [id])
  startAt   DateTime
  endAt     DateTime
  source    String                            // "MOMO" | "VNPAY" | "ADMIN_GRANT"
  createdAt DateTime @default(now())

  @@index([userId, endAt])
}

// --- THANH TOÁN ---

model Payment {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId      String
  plan        VipPlan  @relation(fields: [planId], references: [id])
  amount      Int                            // VNĐ
  gateway     String                         // "MOMO" | "VNPAY"
  gatewayTxId String?  @unique              // mã giao dịch từ cổng thanh toán
  status      String   @default("PENDING")  // "PENDING" | "SUCCESS" | "FAILED" | "REFUNDED"
  rawCallback String?                        // JSON raw response từ gateway
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// --- DAILY TASK CONFIG ---

model DailyTaskConfig {
  id           String   @id @default(uuid())
  taskKey      String   @unique             // "CHECK_IN" | "LISTEN_10" | "WATCH_AD" | "COMMENT" | "REVIEW" | "NOMINATE"
  label        String                       // "Điểm danh hàng ngày"
  description  String?
  creditReward Float
  isActive     Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

// --- PUSH NOTIFICATION ---

model PushNotification {
  id         String    @id @default(uuid())
  title      String
  body       String
  targetType String                          // "ALL" | "VIP" | "USER_IDS" | "STORY_FOLLOWERS"
  targetData String?                         // JSON: danh sách userId hoặc storyId
  status     String    @default("DRAFT")     // "DRAFT" | "SENT" | "FAILED"
  sentAt     DateTime?
  sentCount  Int       @default(0)
  createdBy  String
  createdAt  DateTime  @default(now())
}

model UserFcmToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String                          // "android" | "ios"
  updatedAt DateTime @updatedAt

  @@index([userId])
}
